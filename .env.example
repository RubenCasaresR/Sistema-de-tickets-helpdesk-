# Database
DB_HOST=localhost
DB_NAME=helpdesk
DB_USER=root
DB_PASS=

# Application URL (with leading slash, e.g. /helpdesk or /)
BASE_URL=/helpdesk

# SMTP (optional — configured in helpers/mailer.php)
MAIL_HOST=
MAIL_PORT=587
MAIL_USER=
MAIL_PASS=
MAIL_FROM=noreply@helpdesk.com
MAIL_FROM_NAME=Helpdesk
MAIL_ENCRYPTION=tls
MAIL_BASE_URL=http://localhost

# Session lifetime in seconds (default: 8 hours = 28800)
SESSION_LIFETIME=28800
